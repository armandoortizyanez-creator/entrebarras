{
  "name": "entrebarras",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:web": "turbo run dev --filter=@entrebarras/web",
    "dev:mobile": "turbo run dev --filter=@entrebarras/mobile",
    "build:web": "turbo run build --filter=@entrebarras/web"
  },
  "devDependencies": {
    "@types/node": "^22",
    "prettier": "^3.5.3",
    "turbo": "^2.9.18"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.11.1"
}
